# Plaid (sandbox to start) — sign up free at https://dashboard.plaid.com
# Only needed for this env-var flow if you'd rather not use the Settings page's
# "Bank connection" form (which stores the same keys, encrypted, in the app's
# own database — that's what the packaged desktop app uses, since there's no
# .env.local for a non-technical user to edit). Leave all of this unset and
# the app runs fine with manual data only ("not connected" state).
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# Required only once you connect a bank account via this file (not needed if
# you use the Settings page form instead — the desktop app generates this
# automatically). Generate with: npm run gen-key
ENCRYPTION_KEY=
